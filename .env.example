# Copy to .env.local and paste your Client-side ID from LaunchDarkly.
# Without this, the app runs with default flag values (all control) and no live flag updates.
NEXT_PUBLIC_LAUNCHDARKLY_CLIENT_SIDE_ID=

# Optional: base path for static hosting (e.g. GitHub project Pages at /repo-name/).
# Example for repo "traveld": NEXT_PUBLIC_BASE_PATH=/traveld
# Leave unset for localhost at / or a root custom domain.
NEXT_PUBLIC_BASE_PATH=
